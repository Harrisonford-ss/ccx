#!/usr/bin/env python3
"""ccx — Claude Code provider switcher (CLI).

Manages multiple Anthropic-compatible API endpoints and switches between them
by rewriting only the `env` block of ~/.claude/settings.json. Other top-level
keys (hooks, permissions, enabledPlugins, ...) are preserved untouched.

Storage:  ~/.config/ccx/config.json
Backups:  ~/.config/ccx/backups/   (last 20 settings.json snapshots)
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import sqlite3
import subprocess
import sys
import time
from getpass import getpass
from pathlib import Path
from typing import Any

HOME = Path.home()
CCX_DIR = HOME / ".config" / "ccx"
CCX_CONFIG = CCX_DIR / "config.json"
CCX_BACKUPS = CCX_DIR / "backups"
CLAUDE_SETTINGS = HOME / ".claude" / "settings.json"
CC_SWITCH_DB = HOME / ".cc-switch" / "cc-switch.db"

MANAGED_PREFIXES = ("ANTHROPIC_",)
MANAGED_EXACT = {
    "CLAUDE_CODE_USE_BEDROCK",
    "CLAUDE_CODE_USE_VERTEX",
    "CLAUDE_CODE_API_KEY_HELPER_TTL_MS",
}

BACKUP_KEEP = 20

# ── ANSI colors ──────────────────────────────────────────────

BOLD = "\033[1m"
DIM = "\033[2m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"
CYAN = "\033[36m"
MAGENTA = "\033[35m"
RESET = "\033[0m"


def is_managed(key: str) -> bool:
    return key.startswith(MANAGED_PREFIXES) or key in MANAGED_EXACT


# ── IO helpers ───────────────────────────────────────────────

def atomic_write_text(path: Path, text: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f"{path.name}.tmp.{os.getpid()}.{time.time_ns()}")
    with open(tmp, "w", encoding="utf-8") as f:
        f.write(text)
        f.flush()
        os.fsync(f.fileno())
    if path.exists():
        try:
            os.chmod(tmp, os.stat(path).st_mode)
        except OSError:
            pass
    os.replace(tmp, path)


def atomic_write_json(path: Path, data: Any) -> None:
    atomic_write_text(path, json.dumps(data, indent=2, ensure_ascii=False) + "\n")


def read_json(path: Path, default: Any) -> Any:
    if not path.exists():
        return default
    try:
        with open(path, encoding="utf-8") as f:
            return json.load(f)
    except json.JSONDecodeError as e:
        die(f"failed to parse {path}: {e}")


def die(msg: str, code: int = 1) -> None:
    print(f"{RED}ccx: {msg}{RESET}", file=sys.stderr)
    sys.exit(code)


def mask(value: str) -> str:
    if not isinstance(value, str):
        return str(value)
    if len(value) <= 14:
        return "***"
    return f"{value[:8]}...{value[-4:]}"


def looks_secret(key: str) -> bool:
    k = key.upper()
    return "TOKEN" in k or "KEY" in k or "SECRET" in k


# ── ccx config ───────────────────────────────────────────────

def load_ccx() -> dict:
    cfg = read_json(CCX_CONFIG, {"current": None, "providers": {}})
    cfg.setdefault("current", None)
    cfg.setdefault("providers", {})
    return cfg


def save_ccx(cfg: dict) -> None:
    atomic_write_json(CCX_CONFIG, cfg)


# ── switching ────────────────────────────────────────────────

def backup_settings() -> Path | None:
    if not CLAUDE_SETTINGS.exists():
        return None
    CCX_BACKUPS.mkdir(parents=True, exist_ok=True)
    ts = time.strftime("%Y%m%d-%H%M%S")
    dst = CCX_BACKUPS / f"settings.json.{ts}"
    shutil.copy2(CLAUDE_SETTINGS, dst)
    snapshots = sorted(CCX_BACKUPS.glob("settings.json.*"))
    for old in snapshots[:-BACKUP_KEEP]:
        try:
            old.unlink()
        except OSError:
            pass
    return dst


def apply_env(provider_env: dict) -> None:
    settings = read_json(CLAUDE_SETTINGS, {}) if CLAUDE_SETTINGS.exists() else {}
    if not isinstance(settings, dict):
        die(f"{CLAUDE_SETTINGS} is not a JSON object")
    cur_env = settings.get("env") or {}
    if not isinstance(cur_env, dict):
        die("settings.json `env` is not an object")
    new_env = {k: v for k, v in cur_env.items() if not is_managed(k)}
    for k, v in provider_env.items():
        new_env[k] = v
    settings["env"] = new_env
    atomic_write_json(CLAUDE_SETTINGS, settings)


def clear_env() -> None:
    settings = read_json(CLAUDE_SETTINGS, {}) if CLAUDE_SETTINGS.exists() else {}
    if not isinstance(settings, dict):
        die(f"{CLAUDE_SETTINGS} is not a JSON object")
    cur_env = settings.get("env") or {}
    if not isinstance(cur_env, dict):
        die("settings.json `env` is not an object")
    new_env = {k: v for k, v in cur_env.items() if not is_managed(k)}
    settings["env"] = new_env
    atomic_write_json(CLAUDE_SETTINGS, settings)


# ── interactive menu ─────────────────────────────────────────

def clear_screen() -> None:
    os.system("clear 2>/dev/null || cls 2>/dev/null")


def print_banner() -> None:
    print(f"""
{CYAN}╔════════════════════════════════════╗
║{BOLD}       ccx - Provider Manager       {RESET}{CYAN}║
╚════════════════════════════════════╝{RESET}
""")


def print_current_status(cfg: dict) -> None:
    cur = cfg.get("current")
    if cur and cur in cfg["providers"]:
        p = cfg["providers"][cur]
        env = p.get("env", {})
        url = env.get("ANTHROPIC_BASE_URL", "")
        model = env.get("ANTHROPIC_MODEL", "")
        print(f"  {DIM}Current:{RESET}  {BOLD}{GREEN}{p.get('name', cur)}{RESET}")
        if model:
            print(f"  {DIM}Model:{RESET}    {model}")
        print(f"  {DIM}URL:{RESET}      {url}")
    else:
        print(f"  {DIM}Current:{RESET}  {YELLOW}Account Login (official){RESET}")
    print()


def interactive_main_menu(cfg: dict) -> str | None:
    clear_screen()
    print_banner()
    print_current_status(cfg)

    print(f"  {BOLD}1{RESET}  Switch provider")
    print(f"  {BOLD}2{RESET}  Add provider")
    print(f"  {BOLD}3{RESET}  Remove provider")
    print(f"  {BOLD}4{RESET}  Reset to account login")
    print(f"  {BOLD}q{RESET}  Quit")
    print()
    try:
        choice = input(f"  {BOLD}Choose:{RESET} ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return None
    return choice


def interactive_switch(cfg: dict) -> None:
    providers = cfg["providers"]
    if not providers:
        print(f"\n  {YELLOW}No providers yet. Add one first (option 2).{RESET}")
        input(f"\n  {DIM}Press Enter to go back...{RESET}")
        return

    clear_screen()
    print_banner()
    print(f"  {BOLD}Switch Provider{RESET}\n")

    cur = cfg.get("current")
    keys = list(providers.keys())

    for i, key in enumerate(keys, 1):
        p = providers[key]
        env = p.get("env", {})
        url = env.get("ANTHROPIC_BASE_URL", "?")
        model = env.get("ANTHROPIC_MODEL", "")
        marker = f"{GREEN}●{RESET}" if key == cur else " "
        model_str = f" {DIM}[{model}]{RESET}" if model else ""
        print(f"  {marker} {CYAN}{i}{RESET}  {BOLD}{key}{RESET}  {DIM}{url}{RESET}{model_str}")

    print(f"\n  {CYAN}0{RESET}  {DIM}Back to main menu{RESET}")
    print()

    try:
        choice = input(f"  {BOLD}Enter number:{RESET} ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if choice == "0":
        return

    try:
        idx = int(choice) - 1
    except ValueError:
        print(f"  {RED}Invalid input{RESET}")
        input(f"  {DIM}Press Enter...{RESET}")
        return

    if idx < 0 or idx >= len(keys):
        print(f"  {RED}Out of range{RESET}")
        input(f"  {DIM}Press Enter...{RESET}")
        return

    name = keys[idx]
    p = providers[name]
    env = p.get("env", {})
    backup_settings()
    apply_env(env)
    cfg["current"] = name
    save_ccx(cfg)

    url = env.get("ANTHROPIC_BASE_URL", "?")
    model = env.get("ANTHROPIC_MODEL", "")
    print(f"\n  {GREEN}Switched to {BOLD}{name}{RESET}  {DIM}{url}{RESET}  {DIM}[{model}]{RESET}")
    print(f"\n  {YELLOW}Next: Ctrl+Shift+P → Reload Window, then start a new chat.{RESET}")
    input(f"\n  {DIM}Press Enter...{RESET}")


def interactive_add(cfg: dict) -> None:
    clear_screen()
    print_banner()
    print(f"  {BOLD}Add Provider{RESET}\n")
    print(f"  {CYAN}1{RESET}  Third-party relay  {DIM}(Zhipu, PackyCode, AnyRouter, etc.){RESET}")
    print(f"  {CYAN}2{RESET}  Anthropic official  {DIM}(API key from console.anthropic.com){RESET}")
    print(f"  {CYAN}3{RESET}  Custom")
    print(f"  {CYAN}0{RESET}  Back")
    print()

    try:
        cat = input(f"  {BOLD}Category:{RESET} ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if cat == "0" or not cat:
        return

    if cat == "2":
        default_url = "https://api.anthropic.com"
        default_model = "claude-sonnet-4-5"
    else:
        default_url = ""
        default_model = ""

    print()
    try:
        name = input(f"  {BOLD}Provider name:{RESET} ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if not name:
        print(f"  {RED}Name is required{RESET}")
        input(f"  {DIM}Press Enter...{RESET}")
        return

    if not re.match(r"^[A-Za-z0-9][A-Za-z0-9._-]*$", name):
        print(f"  {RED}Invalid name (use letters, digits, . _ -){RESET}")
        input(f"  {DIM}Press Enter...{RESET}")
        return

    if name in cfg["providers"]:
        print(f"  {RED}'{name}' already exists. Use 'edit' to modify.{RESET}")
        input(f"  {DIM}Press Enter...{RESET}")
        return

    try:
        url = input(f"  {BOLD}API base URL{RESET} [{default_url}]: ").strip()
        if not url:
            url = default_url
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if not url:
        print(f"  {RED}URL is required{RESET}")
        input(f"  {DIM}Press Enter...{RESET}")
        return

    try:
        token = getpass(f"  {BOLD}API token/key{RESET} (hidden): ")
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if not token:
        print(f"  {RED}Token is required{RESET}")
        input(f"  {DIM}Press Enter...{RESET}")
        return

    try:
        model = input(f"  {BOLD}Model{RESET} [{default_model}]: ").strip()
        if not model:
            model = default_model
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if not model:
        model = "claude-sonnet-4-5"

    env = {
        "ANTHROPIC_BASE_URL": url,
        "ANTHROPIC_AUTH_TOKEN": token,
        "ANTHROPIC_MODEL": model,
    }

    cfg["providers"][name] = {"env": env}
    save_ccx(cfg)

    print(f"\n  {GREEN}Added {BOLD}{name}{RESET}  {DIM}{url}{RESET}  {DIM}[{model}]{RESET}")

    try:
        switch_now = input(f"  {BOLD}Switch to it now? [Y/n]:{RESET} ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if switch_now in ("", "y", "yes"):
        backup_settings()
        apply_env(env)
        cfg["current"] = name
        save_ccx(cfg)
        print(f"  {GREEN}Switched to {name}{RESET}")
        print(f"\n  {YELLOW}Next: Ctrl+Shift+P → Reload Window, then start a new chat.{RESET}")

    input(f"\n  {DIM}Press Enter...{RESET}")


def interactive_remove(cfg: dict) -> None:
    providers = cfg["providers"]
    if not providers:
        print(f"\n  {YELLOW}No providers to remove.{RESET}")
        input(f"\n  {DIM}Press Enter to go back...{RESET}")
        return

    clear_screen()
    print_banner()
    print(f"  {BOLD}Remove Provider{RESET}\n")

    cur = cfg.get("current")
    keys = list(providers.keys())

    for i, key in enumerate(keys, 1):
        p = providers[key]
        marker = f"{GREEN}●{RESET}" if key == cur else " "
        print(f"  {marker} {CYAN}{i}{RESET}  {BOLD}{key}{RESET}")

    print(f"\n  {CYAN}0{RESET}  Back")
    print()

    try:
        choice = input(f"  {BOLD}Enter number to remove:{RESET} ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if choice == "0":
        return

    try:
        idx = int(choice) - 1
    except ValueError:
        print(f"  {RED}Invalid input{RESET}")
        input(f"  {DIM}Press Enter...{RESET}")
        return

    if idx < 0 or idx >= len(keys):
        print(f"  {RED}Out of range{RESET}")
        input(f"  {DIM}Press Enter...{RESET}")
        return

    name = keys[idx]
    try:
        confirm = input(f"  {BOLD}Remove '{name}'? [y/N]:{RESET} ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if confirm not in ("y", "yes"):
        print(f"  {DIM}Cancelled{RESET}")
        input(f"  {DIM}Press Enter...{RESET}")
        return

    was_current = cfg.get("current") == name
    del cfg["providers"][name]

    if was_current:
        backup_settings()
        clear_env()
        cfg["current"] = None
        print(f"  {GREEN}Removed {name} and cleared env{RESET}")
    else:
        print(f"  {GREEN}Removed {name}{RESET}")

    save_ccx(cfg)
    input(f"  {DIM}Press Enter...{RESET}")


def interactive_reset(cfg: dict) -> None:
    print()
    try:
        confirm = input(f"  {BOLD}Reset to account login? [y/N]:{RESET} ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if confirm not in ("y", "yes"):
        print(f"  {DIM}Cancelled{RESET}")
        return

    backup_settings()
    clear_env()
    cfg["current"] = None
    save_ccx(cfg)
    print(f"\n  {GREEN}Reset to account login{RESET}")
    print(f"\n  {YELLOW}Next: Ctrl+Shift+P → Reload Window, then start a new chat.{RESET}")


def interactive_loop() -> None:
    cfg = load_ccx()
    while True:
        choice = interactive_main_menu(cfg)
        if choice in ("q", "quit", "exit"):
            print(f"\n  {DIM}Bye!{RESET}\n")
            break
        elif choice == "1":
            interactive_switch(cfg)
        elif choice == "2":
            interactive_add(cfg)
        elif choice == "3":
            interactive_remove(cfg)
        elif choice == "4":
            interactive_reset(cfg)


# ── commands ─────────────────────────────────────────────────

def cmd_list(_args) -> int:
    cfg = load_ccx()
    providers = cfg["providers"]
    if not providers:
        print(f"{DIM}no providers yet — try `ccx add <name>` or `ccx import-cc-switch`{RESET}")
        return 0
    cur = cfg.get("current")
    print(f"\n  {BOLD}ccx providers:{RESET}\n")
    for key, p in providers.items():
        env = p.get("env", {})
        url = env.get("ANTHROPIC_BASE_URL", "?")
        model = env.get("ANTHROPIC_MODEL", "")
        marker = f"{GREEN}*{RESET}" if key == cur else " "
        model_str = f" {DIM}[{model}]{RESET}" if model else ""
        print(f"  {marker} {BOLD}{key}{RESET}  {DIM}{url}{RESET}{model_str}")
    print()
    return 0


def cmd_current(_args) -> int:
    cfg = load_ccx()
    cur = cfg.get("current")
    if not cur:
        print(f"{DIM}using account login (no provider active){RESET}")
        return 0
    p = cfg["providers"].get(cur)
    if not p:
        print(f"{YELLOW}current='{cur}' but provider not found{RESET}")
        return 1
    env = p.get("env", {})
    url = env.get("ANTHROPIC_BASE_URL", "?")
    model = env.get("ANTHROPIC_MODEL", "")
    print(f"{GREEN}{BOLD}{cur}{RESET}  {DIM}{url}{RESET}  {DIM}[{model}]{RESET}")
    return 0


def cmd_use(args) -> int:
    cfg = load_ccx()
    name = args.name

    if name == "__reset__" or name == "reset":
        backup_settings()
        clear_env()
        cfg["current"] = None
        save_ccx(cfg)
        print(f"{GREEN}Switched to account login (env cleared){RESET}")
        return 0

    providers = cfg["providers"]
    if name not in providers:
        die(f"provider '{name}' not found — run `ccx list` to see available")

    p = providers[name]
    env = p.get("env", {})
    backup_settings()
    apply_env(env)
    cfg["current"] = name
    save_ccx(cfg)
    url = env.get("ANTHROPIC_BASE_URL", "?")
    model = env.get("ANTHROPIC_MODEL", "")
    print(f"{GREEN}Switched to {BOLD}{name}{RESET}  {DIM}{url}{RESET}  {DIM}[{model}]{RESET}")
    print(f"\n{YELLOW}Next: Ctrl+Shift+P → Reload Window, then start a new chat.{RESET}")
    return 0


def cmd_add(args) -> int:
    cfg = load_ccx()
    name = args.name
    if name in cfg["providers"]:
        die(f"provider '{name}' already exists — use `ccx edit {name}` to modify")

    url = args.url or ""
    token = args.token or ""
    model = args.model or ""

    interactive = not url or not token

    if interactive:
        print(f"\n  {BOLD}Adding provider: {CYAN}{name}{RESET}\n")
        if not url:
            try:
                url = input(f"  API base URL (e.g. https://api.example.com): ").strip()
            except (EOFError, KeyboardInterrupt):
                print()
                return 1
        if not token:
            try:
                token = getpass(f"  API token/key (hidden): ")
            except (EOFError, KeyboardInterrupt):
                print()
                return 1
        if not model:
            try:
                model = input(f"  Model (default: claude-sonnet-4-20250514): ").strip()
            except (EOFError, KeyboardInterrupt):
                print()
                return 1

    if not url:
        die("URL is required")
    if not token:
        die("token/key is required")
    if not model:
        model = "claude-sonnet-4-20250514"

    env = {
        "ANTHROPIC_BASE_URL": url,
        "ANTHROPIC_AUTH_TOKEN": token,
        "ANTHROPIC_MODEL": model,
    }
    if args.haiku:
        env["ANTHROPIC_DEFAULT_HAIKU_MODEL"] = args.haiku
    if args.sonnet:
        env["ANTHROPIC_DEFAULT_SONNET_MODEL"] = args.sonnet
    if args.opus:
        env["ANTHROPIC_DEFAULT_OPUS_MODEL"] = args.opus

    cfg["providers"][name] = {"env": env}
    save_ccx(cfg)
    print(f"{GREEN}Added {BOLD}{name}{RESET}  {DIM}{url}{RESET}  {DIM}[{model}]{RESET}")
    return 0


def cmd_rm(args) -> int:
    cfg = load_ccx()
    name = args.name
    if name not in cfg["providers"]:
        die(f"provider '{name}' not found")
    if cfg.get("current") == name:
        backup_settings()
        clear_env()
        cfg["current"] = None
    del cfg["providers"][name]
    save_ccx(cfg)
    print(f"{GREEN}Removed {name}{RESET}")
    return 0


def cmd_edit(args) -> int:
    cfg = load_ccx()
    name = args.name
    if name not in cfg["providers"]:
        die(f"provider '{name}' not found")

    p = cfg["providers"][name]
    tmp = tempfile.NamedTemporaryFile(mode="w", suffix=".json", delete=False, encoding="utf-8")
    json.dump(p, tmp, indent=2, ensure_ascii=False)
    tmp.flush()
    tmp.close()

    editor = os.environ.get("EDITOR", os.environ.get("VISUAL", "vi"))
    ret = subprocess.call([editor, tmp.name])
    if ret != 0:
        os.unlink(tmp.name)
        die(f"editor exited with code {ret}")

    try:
        with open(tmp.name, encoding="utf-8") as f:
            new_p = json.load(f)
    except json.JSONDecodeError as e:
        os.unlink(tmp.name)
        die(f"invalid JSON: {e}")
    os.unlink(tmp.name)

    if not isinstance(new_p, dict) or "env" not in new_p:
        die("provider must have an 'env' object")

    cfg["providers"][name] = new_p
    save_ccx(cfg)

    if cfg.get("current") == name:
        backup_settings()
        apply_env(new_p.get("env", {}))
        print(f"{GREEN}Edited and re-applied {name}{RESET}")
    else:
        print(f"{GREEN}Edited {name} (not currently active, run `ccx use {name}` to apply){RESET}")
    return 0


def cmd_show(args) -> int:
    cfg = load_ccx()
    name = args.name
    if name not in cfg["providers"]:
        die(f"provider '{name}' not found")
    p = cfg["providers"][name]
    env = p.get("env", {})
    print(f"\n  {BOLD}{name}{RESET}\n")
    for k, v in env.items():
        display = mask(str(v)) if looks_secret(k) else str(v)
        print(f"    {CYAN}{k}{RESET} = {display}")
    print()
    return 0


def cmd_import_cc_switch(_args) -> int:
    if not CC_SWITCH_DB.exists():
        die(f"cc-switch database not found at {CC_SWITCH_DB}")

    try:
        conn = sqlite3.connect(str(CC_SWITCH_DB))
    except sqlite3.Error as e:
        die(f"failed to open cc-switch db: {e}")

    cur = conn.execute(
        "SELECT id, name, settings_config, is_current FROM providers WHERE app_type = 'claude'"
    )
    rows = cur.fetchall()
    conn.close()

    if not rows:
        print(f"{DIM}no Claude providers found in cc-switch database{RESET}")
        return 0

    cfg = load_ccx()
    imported = 0
    skipped = 0
    for pid, name, settings_json, is_current in rows:
        if name in cfg["providers"]:
            print(f"  {YELLOW}skip{RESET} {name} (already exists in ccx)")
            skipped += 1
            continue
        try:
            settings = json.loads(settings_json)
        except json.JSONDecodeError:
            print(f"  {RED}skip{RESET} {name} (invalid JSON)")
            skipped += 1
            continue
        env = settings.get("env", {})
        if not env:
            print(f"  {YELLOW}skip{RESET} {name} (no env block)")
            skipped += 1
            continue
        cfg["providers"][name] = {"env": env}
        if is_current:
            cfg["current"] = name
        url = env.get("ANTHROPIC_BASE_URL", "?")
        print(f"  {GREEN}imported{RESET} {BOLD}{name}{RESET}  {DIM}{url}{RESET}")
        imported += 1

    if imported > 0:
        save_ccx(cfg)
    print(f"\n  {BOLD}{imported} imported, {skipped} skipped{RESET}")
    return 0


def cmd_reset(_args) -> int:
    cfg = load_ccx()
    backup_settings()
    clear_env()
    cfg["current"] = None
    save_ccx(cfg)
    print(f"{GREEN}Reset to account login{RESET}")
    print(f"\n{YELLOW}Next: Ctrl+Shift+P → Reload Window, then start a new chat.{RESET}")
    return 0


# ── CLI ──────────────────────────────────────────────────────

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="ccx",
        description="Claude Code provider switcher",
        epilog="examples:\n"
               "  ccx add myapi --url https://api.example.com --token sk-xxx\n"
               "  ccx use myapi\n"
               "  ccx list\n"
               "  ccx reset\n",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = p.add_subparsers(dest="command", metavar="CMD")

    # list
    s_list = sub.add_parser("list", aliases=["ls"], help="list all providers")
    s_list.set_defaults(func=cmd_list)

    # current
    s_cur = sub.add_parser("current", help="show current provider")
    s_cur.set_defaults(func=cmd_current)

    # use
    s_use = sub.add_parser("use", help="switch to a provider")
    s_use.add_argument("name", help="provider name or 'reset'")
    s_use.set_defaults(func=cmd_use)

    # add
    s_add = sub.add_parser("add", help="add a new provider")
    s_add.add_argument("name", help="provider name")
    s_add.add_argument("--url", "-u", help="API base URL")
    s_add.add_argument("--token", "-t", help="API token/key")
    s_add.add_argument("--model", "-m", help="default model")
    s_add.add_argument("--haiku", help="haiku model override")
    s_add.add_argument("--sonnet", help="sonnet model override")
    s_add.add_argument("--opus", help="opus model override")
    s_add.set_defaults(func=cmd_add)

    # rm
    s_rm = sub.add_parser("rm", aliases=["remove", "delete"], help="remove a provider")
    s_rm.add_argument("name", help="provider name")
    s_rm.set_defaults(func=cmd_rm)

    # edit
    s_edit = sub.add_parser("edit", help="edit provider config in $EDITOR")
    s_edit.add_argument("name", help="provider name")
    s_edit.set_defaults(func=cmd_edit)

    # show
    s_show = sub.add_parser("show", help="show provider details (secrets masked)")
    s_show.add_argument("name", help="provider name")
    s_show.set_defaults(func=cmd_show)

    # import
    s_imp = sub.add_parser("import-cc-switch", help="import providers from cc-switch database")
    s_imp.set_defaults(func=cmd_import_cc_switch)

    # reset
    s_reset = sub.add_parser("reset", help="reset to account login (clear env)")
    s_reset.set_defaults(func=cmd_reset)

    return p


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()

    if not args.command:
        # no subcommand → interactive menu
        interactive_loop()
        return 0

    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())